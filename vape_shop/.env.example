# ==========================================
# TELEGRAM BOT
# ==========================================
BOT_TOKEN=your_telegram_bot_token_here

# Твій Telegram ID (та інших адмінів через кому)
ADMIN_IDS=123456789

# ==========================================
# БАЗА ДАНИХ
# ==========================================
# Розробка — SQLite (нічого встановлювати не треба)
DATABASE_URL=sqlite:///vape_shop.db
# Production — розкоментуй якщо переходиш на PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/vape_shop

# ==========================================
# ОПЛАТА ТА САМОВИВІЗ
# ==========================================
# Реквізити які отримає клієнт після замовлення
PAYMENT_CARD=0000 0000 0000 0000
PAYMENT_NAME=Твоє Ім'я По Батькові

# Адреса для самовивізу (показується клієнту при виборі самовивозу)
PICKUP_ADDRESS=Велика Михайлівка, вул. Приклад 1 (уточніть час у продавця)

# ==========================================
# TELETHON (автопостинг + парсер каналу)
# ==========================================
# Отримати на my.telegram.org → API development tools
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PHONE=+380XXXXXXXXX
TELEGRAM_CHANNEL_ID=@your_channel_username

# ==========================================
# AI АСИСТЕНТ — Google Gemini (безкоштовно)
# ==========================================
# Отримати на aistudio.google.com → Get API key
GEMINI_API_KEY=your_gemini_api_key_here
# Максимум AI-запитів від одного клієнта за день
AI_DAILY_LIMIT=30

# ==========================================
# ВЕБ-ДАШБОРД
# ==========================================
DASHBOARD_LOGIN=admin
DASHBOARD_PASSWORD=your_strong_password_here
DASHBOARD_PORT=8000

# Production webhook (розкоментуй на хостингу)
# WEBHOOK_URL=https://your-app.railway.app/webhook
