# Токен бота від @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Telegram ID адміністраторів (через кому)
ADMIN_IDS=123456789,987654321

# ID чату/каналу для сповіщень менеджера
MANAGER_CHAT_ID=-100xxxxxxxxxx

# Номер телефону агентства (відображається клієнту)
AGENCY_PHONE=+380XXXXXXXXX

# Адреса магазину/офісу (відображається клієнту)
AGENCY_ADDRESS=м. Київ, вул. Прикладна, 1
